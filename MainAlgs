dados  <- read.xlsx(arquivo_dados, sheet = 1)
dados1 <- as.data.frame(dados[, -1])  # remove coluna do dia, se for a primeira

colnames(dados1) <- c(
  "geracao", "cota", "afluencia", "defluencia",
  "vazao_vertida", "vazao_turbinada",
  "vazao_natural", "vazao_incremental",
  "temp_ins", "temp_max", "temp_min",
  "umi_ins", "umi_max", "umi_min",
  "pto_orvalho_ins", "pto_orvalho_max", "pto_orvalho_min",
  "pressao_ins", "pressao_max", "pressao_min",
  "vel_vento", "rajada_vento",
  "chuva"
)

dados1 <- na.omit(dados1)

# Normalização [0,1] (igual você já vinha usando)
normalize <- function(x) { (x - min(x)) / (max(x) - min(x)) }
dados2 <- as.data.frame(lapply(dados1, normalize))

# Partição treino/teste (precisa ser a mesma dos treinos anteriores)
set.seed(1111)
particao <- createDataPartition(dados2$geracao, p = 0.7, list = FALSE)
treino   <- dados2[particao, ]
teste    <- dados2[-particao, ]

# Para desnormalizar
geracao_min <- min(dados1$geracao)
geracao_max <- max(dados1$geracao)


lista_inicial   <- readRDS(arquivo_modelos_inicial)
lista_filtrados <- readRDS(arquivo_modelos_filtrado)


idx_top1_inicial   <- 1
idx_top1_filtrado  <- 1  

modelo_inicial  <- lista_inicial[[idx_top1_inicial]]
modelo_filtrado <- lista_filtrados[[idx_top1_filtrado]]

#Para a rede do conjunto inicial
teste_inicial <- teste[, vars_iniciais]   # seleciona apenas as colunas usadas
inputs_teste_inicial <- as.matrix(teste_inicial[, colnames(teste_inicial) != "geracao"])

#Para a rede do conjunto filtrado
teste_filtrado <- teste[, vars_filtradas] # seleciona as colunas do conjunto filtrado
inputs_teste_filtrado <- as.matrix(teste_filtrado[, colnames(teste_filtrado) != "geracao"])



# Saída real (em escala original)
y_real <- teste$geracao * (geracao_max - geracao_min) + geracao_min

# --- Rede do conjunto inicial ---
y_pred_norm_inicial <- as.vector(predict(modelo_inicial, inputs_teste_inicial))
y_pred_inicial <- y_pred_norm_inicial * (geracao_max - geracao_min) + geracao_min

# --- Rede do conjunto filtrado ---
y_pred_norm_filtrado <- as.vector(predict(modelo_filtrado, inputs_teste_filtrado))
y_pred_filtrado <- y_pred_norm_filtrado * (geracao_max - geracao_min) + geracao_min


# ============================================================

n <- length(y_real)

