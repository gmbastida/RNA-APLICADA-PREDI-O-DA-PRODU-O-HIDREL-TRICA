calc_metricas <- function(y_real, y_pred) {
  erro <- y_pred - y_real
  erro_abs <- abs(erro)
  erro_rel <- abs(erro / y_real)
  erro_rel[!is.finite(erro_rel)] <- NA

  SSE  <- sum((y_pred - y_real)^2, na.rm = TRUE)
  MSE  <- mean((y_pred - y_real)^2, na.rm = TRUE)
  RMSE <- sqrt(MSE)

  ARE  <- mean(erro_rel, na.rm = TRUE)
  ARED <- ARE * 100

  MAE  <- mean(erro_abs, na.rm = TRUE)
  Bias <- mean(erro, na.rm = TRUE)
  SD   <- sd(erro, na.rm = TRUE)

  R2 <- 1 - sum((y_real - y_pred)^2, na.rm = TRUE) /
            sum((y_real - mean(y_real, na.rm = TRUE))^2, na.rm = TRUE)

  Perc_5  <- mean(erro_rel <= 0.05, na.rm = TRUE) * 100
  Perc_10 <- mean(erro_rel <= 0.10, na.rm = TRUE) * 100

  MediaPorcAcerto <- mean(100 - abs((y_real - y_pred) / y_pred) * 100, na.rm = TRUE)

  data.frame(
    SSE = SSE, MSE = MSE, RMSE = RMSE,
    ARE = ARE, ARED = ARED,
    MAE = MAE, Bias = Bias, DesvioPadrao_Erros = SD,
    R2 = R2,
    Perc_erro_rel_5  = Perc_5,
    Perc_erro_rel_10 = Perc_10,
    MediaPorcAcerto = MediaPorcAcerto
  )
}

