# Função auxiliar: aplica nomes do relatório apenas nas colunas que existirem
aplicar_nomes_relatorio <- function(df, dict) {
  comuns <- intersect(names(df), names(dict))
  names(df)[match(comuns, names(df))] <- dict[comuns]
  df
}

# 

dados_corr <- dados1
dados_corr <- dados_corr[, sapply(dados_corr, function(x) sd(x, na.rm = TRUE) != 0)]

# Matriz de correlação (lida com NA)
mat_cor <- cor(dados_corr, use = "pairwise.complete.obs")



cor_geracao <- mat_cor[, "geracao"]
cor_geracao <- cor_geracao[names(cor_geracao) != "geracao"]  # remove autocorrelação

df_cor_geracao <- data.frame(
  Variavel_original  = names(cor_geracao),
  Variavel_relatorio = nomes_relatorio[names(cor_geracao)],
  Correlacao         = as.numeric(cor_geracao),
  Correlacao_abs     = abs(as.numeric(cor_geracao))
)

# Se alguma variável não tiver mapeamento (NA), usar o nome original como fallback
df_cor_geracao$Variavel_relatorio[is.na(df_cor_geracao$Variavel_relatorio)] <- df_cor_geracao$Variavel_original

# Ordenar (mais forte em |cor| primeiro)
df_cor_geracao <- df_cor_geracao[order(df_cor_geracao$Correlacao_abs, decreasing = TRUE), ]

print(df_cor_geracao)


# Criar fator para ordenar no gráfico
df_plot <- df_cor_geracao
df_plot$Variavel_relatorio <- factor(df_plot$Variavel_relatorio,
                                     levels = rev(df_plot$Variavel_relatorio))

