# ============================================================
# 10. CÁLCULO DE MÉTRICAS COMPARATIVAS ADICIONAIS
# ============================================================

# Erros (resíduos) de cada modelo
erro_inicial  <- y_pred_inicial  - y_real
erro_filtrado <- y_pred_filtrado - y_real

# Erros absolutos
erro_abs_inicial  <- abs(erro_inicial)
erro_abs_filtrado <- abs(erro_filtrado)

# Erro relativo absoluto (em módulo)
erro_rel_inicial  <- abs(erro_inicial  / y_real)
erro_rel_filtrado <- abs(erro_filtrado / y_real)

# Tratar infinidades quando y_real = 0
erro_rel_inicial[!is.finite(erro_rel_inicial)]     <- NA
erro_rel_filtrado[!is.finite(erro_rel_filtrado)]   <- NA

# --- Métricas para o modelo do conjunto inicial ---
MAE_inicial   <- mean(erro_abs_inicial,  na.rm = TRUE)              # erro médio absoluto
RMSE_inicial  <- sqrt(mean(erro_inicial^2, na.rm = TRUE))           # já tinha, mas recalculamos aqui
Bias_inicial  <- mean(erro_inicial,      na.rm = TRUE)              # erro médio (tendência)
SD_inicial    <- sd(erro_inicial,        na.rm = TRUE)              # desvio padrão dos erros
R2_inicial    <- 1 - sum((y_real - y_pred_inicial)^2, na.rm = TRUE) /
                      sum((y_real - mean(y_real))^2,  na.rm = TRUE) # coeficiente de determinação

perc_erro5_inicial  <- mean(erro_rel_inicial  <= 0.05, na.rm = TRUE) * 100  # % erro <= 5%
perc_erro10_inicial <- mean(erro_rel_inicial  <= 0.10, na.rm = TRUE) * 100  # % erro <= 10%


# --- Métricas para o modelo do conjunto filtrado ---
MAE_filtrado   <- mean(erro_abs_filtrado,  na.rm = TRUE)
RMSE_filtrado  <- sqrt(mean(erro_filtrado^2, na.rm = TRUE))
Bias_filtrado  <- mean(erro_filtrado,      na.rm = TRUE)
SD_filtrado    <- sd(erro_filtrado,        na.rm = TRUE)
R2_filtrado    <- 1 - sum((y_real - y_pred_filtrado)^2, na.rm = TRUE) /
                       sum((y_real - mean(y_real))^2,   na.rm = TRUE)

perc_erro5_filtrado  <- mean(erro_rel_filtrado  <= 0.05, na.rm = TRUE) * 100
perc_erro10_filtrado <- mean(erro_rel_filtrado  <= 0.10, na.rm = TRUE) * 100


# --- TABELA RESUMO DE COMPARAÇÃO ENTRE OS DOIS MODELOS ---
tabela_comparacao <- data.frame(
  Modelo              = c("Conjunto inicial", "Conjunto filtrado"),
  MAE                 = c(MAE_inicial,        MAE_filtrado),
  RMSE                = c(RMSE_inicial,       RMSE_filtrado),
  Bias                = c(Bias_inicial,       Bias_filtrado),
  DesvioPadrao_Erros  = c(SD_inicial,         SD_filtrado),
  R2                  = c(R2_inicial,         R2_filtrado),
  `Perc_erro_rel_<=5`   = c(perc_erro5_inicial, perc_erro5_filtrado),
  `Perc_erro_rel_<=10`  = c(perc_erro10_inicial,perc_erro10_filtrado)
)

# Criar uma cópia para arredondar apenas as colunas numéricas
tabela_comparacao_round <- tabela_comparacao

cols_numericas <- sapply(tabela_comparacao_round, is.numeric)

